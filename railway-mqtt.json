{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["python"],
      "phases": {
        "setup": {
          "nixPkgs": ["python311", "python311Packages.paho-mqtt", "python311Packages.requests"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "python3 mqtt_bridge.py"
  }
}
